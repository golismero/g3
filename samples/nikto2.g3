[{"severity": 2, "affects": ["http://example.com:80/"], "taxonomy": ["OSVDB-0"], "references": ["https://github.com/sullo/nikto"], "issues": {"http://example.com:80": [{"path": "/", "cve": ["OSVDB-0"], "msg": "Server leaks inodes via ETags, header found with file /, fields: 0x3147526947+ident "}, {"path": "/", "cve": ["OSVDB-0"], "msg": "The anti-clickjacking X-Frame-Options header is not present."}, {"path": "/", "cve": ["OSVDB-0"], "msg": "Uncommon header 'x-cache' found, with contents: HIT"}, {"path": "/", "cve": ["OSVDB-0"], "msg": "Allowed HTTP Methods: OPTIONS, GET, HEAD, POST "}]}, "_cmd": "nikto.pl -Format xml -output test.xml -Display V -nointeractive -host example.com", "_fp": ["nikto http://example.com/"]}]